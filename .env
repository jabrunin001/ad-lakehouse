# Local-demo credentials only — these are throwaway values for the docker-compose
# lab on a developer machine. Never reuse them anywhere real. Committed on purpose
# so the quickstart is one command.
#
# Kafka / Redpanda
KAFKA_BOOTSTRAP=localhost:19092
KAFKA_TOPIC=ad_events
# MinIO
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=password
AWS_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
WAREHOUSE_BUCKET=warehouse
# Iceberg REST
ICEBERG_REST_URI=http://localhost:8181
